{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020",
    "lib": ["ES2020"],
    "noEmit": false,
    "outDir": "dist-server",
    "jsx": undefined,
    "types": ["node"]
  },
  "include": ["server.ts"],
  "exclude": ["node_modules", "src", ".next"]
}
